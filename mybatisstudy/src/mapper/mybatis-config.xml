<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org/DTD config 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-config.dtd">
<!-- 
  MyBatis 전체 설정 파일 (mybatis-config.xml)
  DB 연결 정보, 트랜잭션 방식, 매퍼 파일 경로 등을 한곳에서 관리함
-->
<configuration>

  <!-- 
    외부 .properties 파일에서 변수값을 불러옴
    아래에서 ${driver}, ${url} 등으로 사용 가능해짐
    mapper/mybatis.properties 파일에 실제 값이 저장되어 있음
  -->
  <properties resource="mapper/mybatis.properties" />
  
  <!-- 클래스의 별명 설정 : 패키지명 생략가능 -->
  <typeAliases>
  	<typeAlias type="main.Member" alias="Member"/>
  	<typeAlias type="main.Student" alias="Student"/>
  	<typeAlias type="main.Professor" alias="Professor"/>
  </typeAliases>
  
  <!-- 
    DB 연결 환경 설정 블록
    여러 환경(개발/운영 등)을 정의할 수 있고,
    default 속성으로 기본으로 사용할 환경을 지정함
  -->
  <environments default="development">
  
    <!-- 개발 환경 설정 (id로 구분) -->
    <environment id="development">
    
      <!-- 
        트랜잭션 관리 방식 설정
        JDBC: 개발자가 직접 commit/rollback을 제어하는 방식
        (Spring 사용 시에는 보통 MANAGED로 바뀜)
      -->
      <transactionManager type="JDBC" />
      
      <!-- 
        데이터소스(DB 커넥션) 설정
        type="POOLED": 커넥션 풀 사용 → 연결을 미리 만들어두고 재사용해서 성능 향상
        type="UNPOOLED": 매번 새로 연결 (소규모/테스트용)
      -->
      <dataSource type="POOLED">
        <!-- JDBC 드라이버 클래스명 (예: com.mysql.cj.jdbc.Driver) -->
        <property name="driver" value="${driver}"/>
        
        <!-- DB 접속 URL (예: jdbc:mysql://localhost:3306/mydb) -->
        <property name="url" value="${url}"/>
        
        <!-- DB 접속 계정명 -->
        <property name="username" value="${username}"/>
        
        <!-- DB 접속 비밀번호 -->
        <property name="password" value="${password}"/>
      </dataSource>
    </environment>
  </environments>

  <!-- 
    SQL 쿼리가 작성된 매퍼 XML 파일 목록 등록
    여기에 등록해야 MyBatis가 해당 SQL을 인식하고 사용할 수 있음
    파일이 여러 개면 <mapper> 태그를 추가로 작성하면 됨
  -->
  <mappers>
    <!-- mapper 폴더 안의 *.xml 파일을 매퍼로 등록 -->
    <mapper resource="mapper/MemberMapper1.xml"/>
    <mapper resource="mapper/StudentMapper1.xml"/>
    <mapper resource="mapper/StudentMapper2.xml"/>
    <mapper resource="test0313/Test1Mapper.xml"/>
    <mapper resource="test0313/Test2Mapper.xml"/>
    
  </mappers>

</configuration>
<!-- 
**핵심 흐름 요약**
mybatis.properties       →  변수값 제공 (driver, url 등)
mybatis-config.xml       →  전체 설정 (연결방식, 환경, 매퍼 목록)
MemberMapper1.xml        →  실제 SQL 쿼리 작성
-->
