<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="test0313.Test2">
	<!-- 1. 교수 테이블에 등록된 레코드의 건수를 출력하기 -->
	<select id="1" resultType="String">
		select count(*) from professor
	</select>
	<!-- 2. 교수 테이블에 등록된 모든 정보를 출력하기 -->
	<select id="2" resultType="Professor">
		select * from professor
	</select>
	<!-- 3. 교수 중 101번 학과의 교수 정보를 출력하기 -->
	<select id="3" parameterType="int" resultType="Professor">
		select * from professor where deptno=#{value}
	</select>
	<!-- 4. 교수 중 성이 김씨인 시간강사 정보를 출력하기 -->
	<select id="4" parameterType="Map" resultType="Professor">
		select * from professor
			<where>
				<if test="name != null and position != null">
					name like concat(#{name}, '%') and position=#{position}
				</if>
			</where>
	</select>
</mapper>